{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    
    "version": "0.2.0",
    "configurations": [
        {
            "name": "{{project_name.snakeCase()}} (ios)",
            "request": "launch",
            "type": "dart",
            "cwd": "${workspaceFolder}",
            "noDebug": true,
            "args": [
                "--dart-define-from-file=config/development.json",
                "--dart-define=config.platform=ios"
            ],
            "env": {}
        },
        {
            "name": "{{project_name.snakeCase()}} (profile mode, ios)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "cwd": "${workspaceFolder}",
            "args": [
                "--dart-define-from-file=config/development.json",
                "--dart-define=config.platform=ios"
            ],
            "env": {}
        },
        {
            "name": "{{project_name.snakeCase()}} (release mode, ios)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "cwd": "${workspaceFolder}",
            "args": [
                "--dart-define-from-file=config/production.json",
                "--dart-define=config.platform=ios"
            ],
            "env": {}
        },
        {
            "name": "{{project_name.snakeCase()}} (android)",
            "request": "launch",
            "type": "dart",
            "cwd": "${workspaceFolder}",
            "noDebug": true,
            "args": [
                "--dart-define-from-file=config/development.json",
                "--dart-define=config.platform=android"
            ],
            "env": {}
        },
        {
            "name": "{{project_name.snakeCase()}} (profile mode, android)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "cwd": "${workspaceFolder}",
            "args": [
                "--dart-define-from-file=config/development.json",
                "--dart-define=config.platform=android"
            ],
            "env": {}
        },
        {
            "name": "{{project_name.snakeCase()}} (release mode, android)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "cwd": "${workspaceFolder}",
            "args": [
                "--dart-define-from-file=config/production.json",
                "--dart-define=config.platform=android"
            ],
            "env": {}
        }
    ]
}